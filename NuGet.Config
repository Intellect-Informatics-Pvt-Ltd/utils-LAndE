<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <packageSources>
    <clear />
    <add key="github" value="https://nuget.pkg.github.com/Intellect-Informatics-Pvt-Ltd/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <!-- GitHub Packages credentials are injected at build time by
       build_push_script.sh from GITHUB_PACKAGES_USERNAME and
       GITHUB_PACKAGES_PAT. Do not commit PATs in this file. -->

  <packageSourceMapping>
    <packageSource key="github">
      <package pattern="Intellect.*" />
    </packageSource>

    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <config>
    <add key="audit" value="true" />
    <add key="auditLevel" value="high" />
  </config>

</configuration>
