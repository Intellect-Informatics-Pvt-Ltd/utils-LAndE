<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github-intellect" value="https://nuget.pkg.github.com/intellect-design/index.json" />
  </packageSources>

  <packageSourceCredentials>
    <github-intellect>
      <add key="Username" value="intellect-design" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_PAT%" />
    </github-intellect>
  </packageSourceCredentials>

  <!-- Package source mapping: required for central package management with multiple sources -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-intellect">
      <package pattern="Intellect.*" />
    </packageSource>
  </packageSourceMapping>

  <!-- Suppress known vulnerability audit errors for legacy bridge dependencies -->
  <config>
    <add key="audit" value="true" />
    <add key="auditLevel" value="high" />
  </config>

</configuration>
