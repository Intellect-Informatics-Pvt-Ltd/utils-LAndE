<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <packageSources>
    <clear />
    <add key="github" value="https://nuget.pkg.github.com/Intellect-Informatics-Pvt-Ltd/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <!-- GitHub Packages credentials. The token is read from the
       GITHUB_PACKAGES_PAT environment variable at restore time.
       - CI: .github/workflows/build.yml exports
         GITHUB_PACKAGES_PAT: ${{ secrets.GITHUB_TOKEN }}, so the
         runner authenticates automatically.
       - Local: set GITHUB_PACKAGES_PAT to a PAT with read:packages
         scope before building, e.g.
         setx GITHUB_PACKAGES_PAT "ghp_yourToken" -->
  <packageSourceCredentials>
    <github>
      <add key="Username" value="intellect-anjaneyulu" />
      <add key="ClearTextPassword" value="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" />
    </github>
  </packageSourceCredentials>

  <packageSourceMapping>
    <packageSource key="github">
      <package pattern="Intellect.*" />
    </packageSource>

    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <config>
    <add key="audit" value="true" />
    <add key="auditLevel" value="high" />
  </config>

</configuration>